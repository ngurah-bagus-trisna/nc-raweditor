{
	"name": "nextcloud/raweditor",
	"description": "Nextcloud RAW image editor for Fujifilm .raf files",
	"type": "project",
	"license": "AGPL-3.0-or-later",
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"nextcloud/ocp": "dev-master",
		"phpunit/phpunit": "^9.5"
	},
	"autoload": {
		"psr-4": {
			"OCA\\RawEditor\\": "lib/"
		}
	},
	"config": {
		"optimize-autoloader": true,
		"classmap-authoritative": true,
		"platform": {
			"php": "8.1"
		}
	}
}
