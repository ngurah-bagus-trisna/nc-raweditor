{
	"name": "raweditor",
	"description": "Nextcloud RAW image editor for Fujifilm .raf files",
	"version": "0.1.0",
	"private": true,
	"license": "AGPL-3.0-or-later",
	"scripts": {
		"build": "NODE_OPTIONS=--max_old_space_size=1024 webpack --node-env production --progress",
		"dev": "webpack --node-env development --progress",
		"watch": "webpack --node-env development --progress --watch",
		"lint": "eslint --ext .js,.vue src"
	},
	"browserslist": [
		"extends @nextcloud/browserslist-config"
	],
	"dependencies": {
		"@nextcloud/auth": "^2.4.0",
		"@nextcloud/axios": "^2.5.1",
		"@nextcloud/dialogs": "^5.3.7",
		"@nextcloud/files": "^3.9.0",
		"@nextcloud/initial-state": "^2.2.0",
		"@nextcloud/l10n": "^3.1.0",
		"@nextcloud/router": "^3.0.1",
		"@nextcloud/vue": "^8.19.0",
		"vue": "^2.7.16",
		"vue-material-design-icons": "^5.3.1",
		"vue-router": "^3.6.5"
	},
	"devDependencies": {
		"@nextcloud/babel-config": "^1.2.0",
		"@nextcloud/browserslist-config": "^3.0.1",
		"@nextcloud/eslint-config": "^8.4.1",
		"@nextcloud/webpack-vue-config": "^6.1.1",
		"eslint-webpack-plugin": "^4.2.0"
	},
	"engines": {
		"node": ">=20.0.0",
		"npm": "^10.0.0"
	}
}
